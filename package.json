{
  "name": "mcp-registry",
  "version": "1.0.0",
  "private": true,
  "description": "The Skill Registry for MCP-compatible AI agents.",
  "packageManager": "npm@10.9.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "validate": "tsx scripts/validate-registry.ts",
    "check": "npm run lint && npm run test && npm run validate"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "registry",
    "skills",
    "ai-agents",
    "agentnxt"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AGenNext/mcp-registry.git"
  },
  "devDependencies": {
    "tsx": "4.20.6"
  }
}
